# === DATABASE ===
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/dbname?sslmode=disable

# === APP ===
NODE_ENV=production
PORT=3001
AUTH_MODE=local
STORAGE_MODE=local
BASE_URL=https://app.fnbcostpro.com
APP_BASE_URL=https://app.fnbcostpro.com

# === AUTH ===
SESSION_SECRET=a-long-random-string-at-least-32-chars

# === EMAIL (SMTP2GO) ===
SMTP2GO_USERNAME=your-smtp2go-username
SMTP2GO_PASSWORD=your-smtp2go-password
SMTP_FROM_EMAIL=no-reply@fnbcostpro.com
SMTP_FROM_NAME=FNB Cost Pro
# SMTP2GO_HOST=mail.smtp2go.com   # default - no change needed
# SMTP2GO_PORT=587                # default - no change needed

# === STRIPE (required when billing goes live) ===
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === QUICKBOOKS (optional) ===
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=

# === EDI Gateway (optional) ===
# EDI_GATEWAY_BASE_URL=
# EDI_GATEWAY_TOKEN=
# AS2_INBOUND_HMAC_SECRET=
# EDI_WEBHOOK_SECRET=
